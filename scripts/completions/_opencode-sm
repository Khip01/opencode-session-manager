#compdef opencode-sm
# zsh completion for opencode-sm
# Install: copy to a directory in $fpath (e.g. /usr/share/zsh/site-functions/)

_opencode_sm() {
    local -a opts
    opts=(
        '--db-path[Path to opencode.db (default: ~/.local/share/opencode/opencode.db)]:directory:_directories'
        '--watch[Auto-refresh session list when opencode.db changes]'
        '--version[Print version and exit]'
        '--help[Show help]'
    )

    _arguments -s $opts
}

_opencode_sm "$@"
